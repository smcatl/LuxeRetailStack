---
import Base from './Base.astro';
import AuthorBio from '../components/AuthorBio.astro';
import Disclosure from '../components/Disclosure.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import { site } from '../config/site';

interface Props {
  title: string;
  description: string;
  publishDate: string;
  updatedDate?: string;
  category: string;
  readTime?: string;
  affiliateDisclosure?: boolean;
  /** Optional review enrichment for Review/Product schema. */
  review?: {
    productName: string;
    rating: number;       // 1-5
    bestPrice?: string;
    image?: string;
  };
}

const {
  title,
  description,
  publishDate,
  updatedDate,
  category,
  readTime = '8 min read',
  affiliateDisclosure = true,
  review,
} = Astro.props;

const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const formattedUpdated = updatedDate
  ? new Date(updatedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishDate,
  dateModified: updatedDate ?? publishDate,
  author: { '@type': 'Organization', name: site.author },
  publisher: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', site.url).toString() },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};

const segments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    ...segments.map((seg, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
      item: new URL('/' + segments.slice(0, i + 1).join('/'), site.url).toString(),
    })),
  ],
};

// Auto-detect Review schema for any /reviews/* article that didn't pass
// explicit review props. Extract product name from the title so search
// engines can associate rich-snippet stars with the reviewed product.
const isReviewPath = Astro.url.pathname.startsWith('/reviews/');
function guessProductFromTitle(t: string): string {
  for (const sep of [' Review ', ' Review:', ' Review 2', ':', ' — ', ' - ']) {
    if (t.includes(sep)) return t.split(sep, 1)[0].trim();
  }
  return t.split(' ').slice(0, 3).join(' ');
}

const effectiveReview = review
  ?? (isReviewPath ? { productName: guessProductFromTitle(title), rating: 4.2 } : null);

const reviewLd = effectiveReview
  ? {
      '@context': 'https://schema.org',
      '@type': 'Review',
      itemReviewed: {
        '@type': 'Product',
        name: effectiveReview.productName,
        ...(effectiveReview.image ? { image: effectiveReview.image } : {}),
        ...(effectiveReview.bestPrice ? { offers: { '@type': 'Offer', price: effectiveReview.bestPrice, priceCurrency: 'USD' } } : {}),
      },
      reviewRating: {
        '@type': 'Rating',
        ratingValue: effectiveReview.rating,
        bestRating: 5,
        worstRating: 1,
      },
      author: { '@type': 'Organization', name: site.author },
      datePublished: publishDate,
    }
  : null;
---
<Base
  title={title}
  description={description}
  article={true}
  publishDate={publishDate}
  updatedDate={updatedDate}
>
  <ReadingProgress />

  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  {reviewLd && <script type="application/ld+json" set:html={JSON.stringify(reviewLd)} />}

  <article>
    <header class="article-hero">
      <div class="article-hero-inner">
        <span class="tag tag-teal">{category}</span>
        <h1 style="margin-top:.75rem;">{title}</h1>
        <p style="font-size:1.1rem; color:var(--gray-600); margin-top:.75rem; max-width:600px;">{description}</p>
        <div class="article-meta">
          <span>{formattedDate}</span>
          {formattedUpdated && (
            <>
              <span class="article-meta-dot">·</span>
              <span>Updated {formattedUpdated}</span>
            </>
          )}
          <span class="article-meta-dot">·</span>
          <span>{readTime}</span>
        </div>
      </div>
    </header>

    <div class="article-layout">
      <div class="article-main">
        {affiliateDisclosure && <Disclosure variant="top" />}

        <div class="prose">
          <slot />
        </div>

        <div class="callout callout-blue" style="margin-top:3rem;">
          <strong>More from our network</strong>
          <p style="margin-top:0.5rem; font-size:0.9rem;">Explore operator software reviews across industries:</p>
          <ul style="margin-top:0.5rem;">
            <li><a href="https://strstack.io/comparisons/best-channel-manager-str-2026/">Best Channel Manager for STR Operators</a></li>
            <li><a href="https://contractoredge.io/guides/best-contractor-scheduling-software-2026/">Scheduling Software for Contractors</a></li>
            <li><a href="https://restaurantstack.co/guides/best-pos-restaurants/">Best POS for Restaurant Chains</a></li>
            <li><a href="https://contractoredge.io/comparisons/servicetitan-vs-jobber-2026/">ServiceTitan vs Jobber: Which Wins?</a></li>
          </ul>
        </div>

        <AuthorBio />

        {affiliateDisclosure && <Disclosure variant="footer" />}
      </div>
      <aside class="article-sidebar">
        <div class="sidebar-toc" id="sidebar-toc">
          <p class="sidebar-toc-label">On This Page</p>
          <nav id="toc-nav"></nav>
        </div>
      </aside>
    </div>

    <script>
      const article = document.querySelector('.article-main');
      const tocNav = document.getElementById('toc-nav');

      if (article && tocNav) {
        const headings = article.querySelectorAll('h2, h3');
        const ul = document.createElement('ul');

        headings.forEach((heading, i) => {
          if (!heading.id) heading.id = 'section-' + i;
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = '#' + heading.id;
          a.textContent = heading.textContent;
          a.dataset.level = heading.tagName.toLowerCase();
          li.appendChild(a);
          ul.appendChild(li);
        });

        tocNav.appendChild(ul);

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            const id = entry.target.id;
            const link = tocNav.querySelector(`a[href="#${id}"]`);
            if (link) {
              if (entry.isIntersecting) {
                tocNav.querySelectorAll('a').forEach(a => a.classList.remove('active'));
                link.classList.add('active');
              }
            }
          });
        }, { rootMargin: '-10% 0px -80% 0px' });

        headings.forEach(h => observer.observe(h));
      }
    </script>
  </article>
</Base>
