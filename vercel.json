{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "astro",
  "redirects": [
    {
      "source": "/recommends/shopify-plus",
      "destination": "https://www.shopify.com/plus",
      "permanent": false
    },
    {
      "source": "/recommends/klaviyo",
      "destination": "https://www.klaviyo.com/",
      "permanent": false
    },
    {
      "source": "/recommends/gorgias",
      "destination": "https://www.gorgias.com/",
      "permanent": false
    },
    {
      "source": "/recommends/triplewhale",
      "destination": "https://www.triplewhale.com/",
      "permanent": false
    },
    {
      "source": "/recommends/cin7",
      "destination": "https://www.cin7.com/",
      "permanent": false
    },
    {
      "source": "/recommends/liverecover",
      "destination": "https://liverecover.com/",
      "permanent": false
    },
    {
      "source": "/recommends/gohighlevel",
      "destination": "https://www.gohighlevel.com/?fp_ref=stosh61",
      "permanent": false
    },
    {
      "source": "/recommends/unbounce",
      "destination": "https://unbounce.com/",
      "permanent": false
    },
    {
      "source": "/recommends/aweber",
      "destination": "https://www.aweber.com/easy-email.htm?id=560455",
      "permanent": false
    },
    {
      "source": "/recommends/jotform",
      "destination": "https://www.jotform.com/",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 2"
    },
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 3"
    },
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 4"
    },
    {
      "path": "/api/refill-queue",
      "schedule": "0 13 * * 0"
    }
  ]
}
